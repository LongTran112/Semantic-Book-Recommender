# Copy this file to .env and set secure values before production deploy.

# Core guardrails
RAG_API_KEY=replace-with-strong-random-secret
RAG_RATE_LIMIT_WINDOW_SEC=60
RAG_RATE_LIMIT_MAX_REQUESTS=30

# API index path inside container
RAG_INDEX_DIR=/app/output/semantic_index_chunks

# Ollama defaults
OLLAMA_MODEL=granite3.3:8b
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# Optional runtime settings
TZ=UTC
PUBLIC_BASE_URL=https://your-domain.example

# Optional: keep Hugging Face model cache inside project output/
# Use absolute paths so behavior is consistent across shells.
HF_HOME=/Users/longtran/Projects/EBooksSorter/output/hf_cache
HF_HUB_CACHE=/Users/longtran/Projects/EBooksSorter/output/hf_cache/hub

# Optional source library mount if running indexing inside containers
EBOOKS_SOURCE_DIR=/data/library
